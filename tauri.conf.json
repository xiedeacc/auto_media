{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Media",
  "version": "0.1.0",
  "identifier": "local.auto-media",
  "build": {
    "frontendDist": "src/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Auto Media",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

